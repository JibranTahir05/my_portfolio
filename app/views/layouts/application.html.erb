<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "My Portfolio" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
<%= stylesheet_link_tag "application.css" %>
  <body>
<div class="container">
  <header class="fade-in">
    <h1>Jibran Tahir</h1>
    <p>Student · Developer · Canva Professional</p>
  </header>

  <section class="about fade-in">
    <h2>About Me</h2>
    <p>
      My name is <strong>Jibran Tahir</strong>, a passionate student based in <strong>Faisalabad, Pakistan</strong>, currently studying at <strong>The University of Faisalabad</strong>. I specialize in front-end development and am a Canva professional with a keen eye for clean, modern design. I enjoy bringing ideas to life through code and creativity. Outside of academics and design, I’m an avid gamer and love solving complex problems.
    </p>
  </section>

  <section class="projects fade-in">
    <h2>Projects</h2>
    <ul>
      <li>🌟 Canva Design Portfolio</li>
      <li>💻 Front-End Website Project</li>
    </ul>
  </section>

<div class="contact-button fade-in">
  <button id="contact-toggle-btn">Contact Me</button>
  <div id="contact-info" style="display: none; margin-top: 10px;">
    <p><strong>Email:</strong> jibran@example.com</p>
    <p><strong>Location:</strong> Faisalabad, Pakistan</p>
  </div>
</div>
  <p id="cta-result"></p>
</div>
    <%= yield %>
  </body>
</html>
